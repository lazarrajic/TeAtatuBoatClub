# ─── Booking system secrets (Netlify environment variables) ──────────────
# These are read ONLY inside netlify/functions/* — never exposed to the browser.

# Supabase (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, full access

# Resend transactional email (https://resend.com)
RESEND_API_KEY=re_your_key
EMAIL_FROM="Te Atatū Boating Club <bookings@teatatuboatclub.co.nz>"  # TODO: verify domain in Resend
EMAIL_OFFICE=office@teatatuboatclub.co.nz
EMAIL_MANAGER=office@teatatuboatclub.co.nz        # TODO: confirm real manager@ address with Dan

# Shared password for the /admin bookings view
ADMIN_PASSWORD=change-me

# ─── Frontend (exposed to the browser — safe, public) ────────────────────
# The custom CMS content API endpoint for this client. Used at runtime to read
# live pricing + notice wording. Falls back to content.js if unset/unreachable.
VITE_CMS_API=https://your-cms-url.com/api/content/TE_ATATU_CLIENT_ID
